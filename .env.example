# Kapitali Environment Variables

# Groq
GROQ_API_KEY=

# Database
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/kapitali

# Auth (Clerk or Auth.js)
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=
CLERK_SECRET_KEY=
# or
AUTH_SECRET=

# Embeddings (OpenAI or open-source)
OPENAI_API_KEY=
# or
EMBEDDINGS_MODEL=BAAI/bge-base-en-v1.5

# Frontend
NEXT_PUBLIC_API_URL=http://localhost:8000

# Backend
BACKEND_PORT=8000
FRONTEND_URL=http://localhost:3000
